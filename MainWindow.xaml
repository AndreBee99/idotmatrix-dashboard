<Window x:Class="idotmatrix_gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:idotmatrix_gui"
        mc:Ignorable="d"
        Title="iDotMatrix DIY Dashboard" Height="750" Width="1200"
        Background="#0B0B0F" Foreground="#E5E5E9"
        WindowStartupLocation="CenterScreen" SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    
    <Window.Resources>
        <!-- Modern Dark Theme Styles -->
        <SolidColorBrush x:Key="BgBrush" Color="#0B0B0F"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#12121C"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#00F0FF"/>
        <SolidColorBrush x:Key="AccentMagenta" Color="#FF007F"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#1ED760"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#222235"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8B8B9F"/>

        <!-- Custom Scrollbar styling -->
        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" 
                                       HorizontalAlignment="Right" 
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}" 
                                       Maximum="{TemplateBinding ScrollableHeight}" 
                                       ViewportSize="{TemplateBinding ViewportHeight}" 
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Width="8"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded, Glowing Card Style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <!-- Hover-sensitive Neon Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1A1A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#25253D"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Special Theme Buttons -->
        <Style x:Key="CyanButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
            <Setter Property="Background" Value="#002A35"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#004A5C"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MagentaButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderBrush" Value="{StaticResource AccentMagenta}"/>
            <Setter Property="Background" Value="#350020"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5C0038"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentMagenta}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#09090F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentCyan}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- Header Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content Area -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER BAR -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App Title with Neon Accent -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="iDotMatrix" FontSize="26" FontWeight="Black" Foreground="White"/>
                <TextBlock Text=" DIY DASHBOARD" FontSize="26" FontWeight="Light" Foreground="{StaticResource AccentCyan}"/>
            </StackPanel>

            <!-- BLE Status Dashboard -->
            <Border Grid.Column="1" Background="#12121F" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ElStatusIndicator" Width="10" Height="10" Fill="Red" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtStatus" Text="Disconnected" FontWeight="Bold" FontSize="13" Foreground="Red" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    
                    <TextBlock Text="MAC:" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11" FontWeight="Bold"/>
                    <TextBox x:Name="TxtMacAddress" Text="00:00:00:00:00:00" Width="125" Height="22" FontSize="11" Padding="4,1" VerticalAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,15,0"/>

                    <Button x:Name="BtnConnect" Content="CONNECT" Style="{StaticResource CyanButton}" Click="BtnConnect_Click" VerticalAlignment="Center" Padding="10,4"/>
                    <Button x:Name="BtnDisconnect" Content="DISCONNECT" Style="{StaticResource MagentaButton}" Click="BtnDisconnect_Click" VerticalAlignment="Center" Margin="8,0,0,0" Padding="10,4" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- LED Matrix Preview (Left) -->
                <ColumnDefinition Width="380"/>
                <!-- Scene Carousel Manager (Center) -->
                <ColumnDefinition Width="*"/>
                <!-- Config & Terminal (Right) -->
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: LED MATRIX PREVIEW -->
            <StackPanel Grid.Column="0">
                <!-- Preview Card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <!-- Card Header -->
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="LED DISPLAY SIMULATOR" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="TxtFps" Text="20 FPS" FontSize="11" Foreground="{StaticResource AccentCyan}" HorizontalAlignment="Right" FontWeight="Bold"/>
                        </Grid>
                        
                        <!-- Pixel Matrix Frame -->
                        <Border BorderBrush="#30304C" BorderThickness="4" Background="Black" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="4">
                            <Grid>
                                <!-- The Upscaled 32x32 WriteableBitmap -->
                                <Image x:Name="ImgLedPreview" Width="320" Height="320" 
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Stretch="Fill"/>
                                
                                <!-- Mesh overlay representing the LED pixels separator grid for realistic rendering -->
                                <Grid Width="320" Height="320" IsHitTestVisible="False" Opacity="0.12">
                                    <Grid.Background>
                                        <DrawingBrush TileMode="Tile" Viewport="0,0,10,10" ViewportUnits="Absolute">
                                            <DrawingBrush.Drawing>
                                                <GeometryDrawing Geometry="M0,0 H10 V10 H0 Z">
                                                    <GeometryDrawing.Pen>
                                                        <Pen Brush="Black" Thickness="2"/>
                                                    </GeometryDrawing.Pen>
                                                </GeometryDrawing>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Grid.Background>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Device Info & Action Controls -->
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="TARGET DEVICE" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="IDM-907983" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                <TextBlock Text="MAC: A0:3E:49:90:79:83" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="DIY MODE COMMAND" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                <Button x:Name="BtnForceDiy" Content="Force DIY Mode" Style="{StaticResource CyanButton}" Margin="0,4,0,0" Padding="0,6" Click="BtnForceDiy_Click"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Audio Capture Status Card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="WASAPI LOOPBACK AUDIO CAPTURE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtAudioStatus" Text="Listening to system audio..." FontSize="12" Foreground="{StaticResource AccentGreen}"/>
                            <ProgressBar x:Name="PbAudioLevel" Grid.Column="1" Width="100" Height="10" Background="#111" Foreground="{StaticResource AccentGreen}" Maximum="1.0" Value="0.0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- CENTER COLUMN: SCENE CAROUSEL MANAGER -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="SCENE CAROUSEL PLAYLIST BUILDER" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock Text="Cycle order &amp; active scenes" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Playlist ListView -->
                    <ListView x:Name="LvPlaylist" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="#161625"/>
                                <Setter Property="BorderBrush" Value="#222238"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1E1E32"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2A1A3F"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentMagenta}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Active Checkbox -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Scene Name -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Duration -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Actions -->
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Enabled Checkbox -->
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="5,0,15,0" Checked="OnPlaylistItemChanged" Unchecked="OnPlaylistItemChanged"/>

                                    <!-- Scene Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding Scene.Name}" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>

                                    <!-- Duration Editor -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                                        <TextBlock Text="Duration:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                        <TextBox Width="40" Text="{Binding DurationSeconds, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" FontSize="12" Padding="4,2" Background="#09090F" BorderBrush="#333" Foreground="White" LostFocus="OnDurationLostFocus"/>
                                        <TextBlock Text="s" VerticalAlignment="Center" Margin="3,0,0,0" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>

                                    <!-- Trigger Buttons -->
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Play Now" Click="BtnPlayScene_Click" Style="{StaticResource CyanButton}" Padding="8,4" FontSize="11" Margin="0,0,5,0"/>
                                        <Button Content="▲" Click="BtnMoveUp_Click" Padding="6,4" FontSize="9" Margin="0,0,2,0"/>
                                        <Button Content="▼" Click="BtnMoveDown_Click" Padding="6,4" FontSize="9"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Bottom Controls -->
                    <StackPanel Grid.Row="2" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Automatic transitions: Paint Melt, VHS Glitch, Sine Wave" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,15,0" FontStyle="Italic"/>
                        <Button Content="FORCE NEXT SCENE" Style="{StaticResource MagentaButton}" Click="BtnForceNext_Click" Padding="15,8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT COLUMN: CONFIG & REALTIME TERMINAL -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <!-- Settings -->
                    <RowDefinition Height="Auto"/>
                    <!-- Terminal Logs -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Scene Specific Config Card -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="INTEGRATION SETTINGS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>

                        <!-- Weather Settings -->
                        <TextBlock Text="WEATHER LOCATION (OPEN-METEO)" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtWeatherCity" Text="London" Grid.Column="0" VerticalContentAlignment="Center"/>
                            <Button x:Name="BtnSaveWeather" Content="SEARCH" Grid.Column="1" Margin="6,0,0,0" Style="{StaticResource CyanButton}" Click="BtnSaveWeather_Click" Width="80"/>
                        </Grid>
                        <TextBlock x:Name="TxtCoordinates" Text="Lat: 51.5074, Lon: -0.1278" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,-6,0,12"/>

                        <!-- Calendar Settings -->
                        <TextBlock Text="CALENDAR SYNC (ICAL FEED URL)" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtCalendarUrl" Text="" Grid.Column="0" VerticalContentAlignment="Center"/>
                            <Button x:Name="BtnSaveCalendar" Content="SAVE" Grid.Column="1" Margin="6,0,0,0" Style="{StaticResource CyanButton}" Click="BtnSaveCalendar_Click" Width="80"/>
                        </Grid>
                        <TextBlock Text="e.g. Google Calendar Secret iCal Address" FontSize="9" Foreground="#555" Margin="0,0,0,5"/>
                    </StackPanel>
                </Border>

                <!-- REAL-TIME LOGGING TERMINAL -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="SYSTEM DIAGNOSTICS LOG" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                        
                        <!-- Terminal Log TextBox -->
                        <TextBox x:Name="TxtLogTerminal" Grid.Row="1" IsReadOnly="True" 
                                 FontFamily="Consolas" FontSize="11" Background="#05050A" 
                                 BorderBrush="#20202F" Foreground="#00F0FF" 
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                                 AcceptsReturn="True" TextWrapping="Wrap"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
